# Copy to .env.local for local dev. Set all of these in Vercel Environment Variables.

# Supabase — get from: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — get from: resend.com > API Keys
RESEND_API_KEY=re_...

# Admin dashboard password (choose a strong password)
ADMIN_PASSWORD=change-me-strong-password

# Admin notification email
ADMIN_EMAIL=your@email.com

# Public base URL (no trailing slash)
# During Vercel preview: use your Vercel deployment URL
# After domain migration: https://rotationanalytics.ca
NEXT_PUBLIC_BASE_URL=https://your-deployment.vercel.app
